# ---- App ----
NODE_ENV=development
PORT=8000
STORAGE_PROVIDER=R2

# ---- Rate Limiting ----
ENABLE_RATE_LIMIT=true
GLOBAL_RATE_LIMIT=100
AUTH_RATE_LIMIT=5
UPLOAD_RATE_LIMIT=30
API_RATE_LIMIT=60
INTEGRATION_RATE_LIMIT=20
REFRESH_TOKEN_RATE_LIMIT=10

# ---- Database ----
DATABASE_URL=

# ---- Frontend / CORS ----
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ---- Auth Tokens ----
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=30m

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d

# ---- Google OAuth ----
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_CALLBACK_URL=
GOOGLE_INTEGRATION_CALLBACK_URL=http://localhost:8000/api/v1/integrations/callback/google

# ---- GitHub OAuth ----
GITHUB_LOGIN_CLIENT_ID=
GITHUB_LOGIN_CLIENT_SECRET=
GITHUB_LOGIN_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback

# ---- Email ----
BREVO_SMTP_PASS=
BREVO_SMTP_USER=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_FROM=


# ---- CloudFlare R2 ----
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_AVATAR_BUCKET_NAME=
R2_TOKEN_VALUE=
R2_AVATARS_PUBLIC_BASE_URL=