#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# commit-msg hook to validate conventional commits
# Ensures commit messages follow the conventional commits format

commit_msg=$(cat "$1")

# Conventional Commits pattern
# Format: type(scope?): description
# Examples:
# feat: add new feature
# feat(auth): add OAuth login
# fix(api): fix validation error
# docs: update README
# style: format code
# refactor: restructure modules
# perf: improve performance
# test: add unit tests
# chore: update dependencies

pattern='^(feat|fix|docs|style|refactor|perf|test|chore|ci|build)(\(.+\))?!?: .{1,}$'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Invalid commit message format!"
  echo ""
  echo "✅ Conventional Commits format required:"
  echo "   <type>[optional scope]: <description>"
  echo ""
  echo "✓ Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, build"
  echo "✓ Example: feat(auth): add OAuth login"
  echo "✓ Example: fix: resolve validation error"
  echo ""
  exit 1
fi

exit 0
